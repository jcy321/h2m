{
  "name": "h2m",
  "version": "1.0.0",
  "description": "HTML to Markdown Converter - A minimalist web tool for converting HTML to Markdown",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "build": "bun build src/server.ts --outdir ./dist --target bun",
    "start": "bun run src/server.ts",
    "test": "bun test"
  },
  "dependencies": {
    "hono": "^4.0.0",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/turndown": "^5.0.0",
    "typescript": "^5.0.0"
  },
  "author": "OpenCode",
  "license": "MIT"
}